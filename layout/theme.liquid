<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    <link rel="stylesheet" href="https://use.typekit.net/tyo2avh.css">
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css"
    />
    <link rel="stylesheet" href="https://use.typekit.net/tyo2avh.css">
    <script src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"></script>
    <style>
      .upcart-cart{
  /* Brand tokens */
  --fbs-font: Quantico, sans-serif;
  --fbs-bg: #FFB21A;           /* cart yellow */
  --fbs-border: #000000;       /* black outline */
  --fbs-shadow: #C81E2A;       /* red 3D plate */
  --fbs-card: #FFFFFF;
  --fbs-radius: 10px;
  --fbs-radius-lg: 14px;

  /* Make UpCart defaults stop looking muted/faded */
  --upcart-internal-design-text-color: #000000;
  --upcart-internal-announcements-border-color: #000000;

  background: var(--fbs-bg) !important;
  color: var(--fbs-border);
}

/* ---- Divider consistency (header/announcement/footer) ---- */
.upcart-cart .upcart-public-header{
  border-bottom: 2px solid var(--fbs-border) !important;
}

.upcart-cart .upcart-public-announcement{
  background: var(--fbs-bg) !important;
  border-top: 2px solid var(--fbs-border) !important;
  border-bottom: 2px solid var(--fbs-border) !important;
}

.upcart-footer{
  border-top: 2px solid var(--fbs-border) !important;
  background: transparent !important;
}

/* ---- Typography: header + titles ---- */
.upcart-cart h3[data-upcart-chunk="header-title-content"]{
  font-family: var(--fbs-font) !important;
  font-weight: 700 !important;
  color: var(--fbs-border) !important;
  letter-spacing: 0.2px;
}

.upcart-cart
.upcart-public-component-product-tile__product-title,
.upcart-cart
.upcart-public-component-product-tile__title-link,
.upcart-cart
.upcart-public-component-product-tile__product-title *{
  font-family: var(--fbs-font) !important;
  font-weight: 700 !important;
  color: var(--fbs-border) !important;
  text-transform: uppercase;
  letter-spacing: 0.2px;
}

/* ---- Variant line (Size: Medium) — force solid, not faded ---- */
#upCart .upcart-cart .upcart-public-component-product-tile__variant
.upcart-internal-cart-items__key-value-pair{
  font-family: var(--fbs-font) !important;
  font-weight: 400 !important;
  color: var(--fbs-border) !important;
  opacity: 1 !important;
  filter: none !important;
}

/* ---- Product image tile ---- */
.upcart-cart
.upcart-public-component-product-tile__image-wrapper,
.upcart-cart
.upcart-product-image-wrapper{
  width: 113px;
  height: 116px;
  border-radius: var(--fbs-radius);
  overflow: hidden;
  background: var(--fbs-card);
  border: 2px solid var(--fbs-border);
  box-sizing: border-box;
}

.upcart-cart .upcart-public-component-product-tile__image{
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

/* ---- Quantity selector (clean arcade outline, NOT as loud as CTA) ---- */
.upcart-cart .upcart-public-component-product-tile__quantity-selector{
  display: inline-flex;
  align-items: center;
  justify-content: space-between;

  height: 44px;
  min-width: 150px;
  padding: 0 10px;

  background: var(--fbs-card);
  border: 2px solid var(--fbs-border);
  border-radius: var(--fbs-radius);
  box-sizing: border-box;
}

.upcart-cart .upcart-public-component-product-tile__quantity-minus,
.upcart-cart .upcart-public-component-product-tile__quantity-plus{
  border: 0;
  background: transparent;
  padding: 0;
  height: 100%;
  width: 44px;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  color: var(--fbs-border);
  cursor: pointer;
}

.upcart-cart .upcart-public-component-product-tile__quantity-minus svg,
.upcart-cart .upcart-public-component-product-tile__quantity-plus svg{
  width: 18px;
  height: 18px;
  display: block;
}

.upcart-cart .upcart-public-component-product-tile__quantity-minus svg path,
.upcart-cart .upcart-public-component-product-tile__quantity-plus svg path{
  fill: currentColor;
}

.upcart-cart .upcart-public-component-product-tile__quantity-selector input{
  border: 0;
  background: transparent;
  outline: none;
  box-shadow: none;

  width: 40px;
  text-align: center;

  font-family: var(--fbs-font) !important;
  font-size: 18px;
  font-weight: 700;
  line-height: 1;
  color: var(--fbs-border);
  -webkit-appearance: none;
  appearance: none;
}

/* ---- Remove button (trash) — make it consistent (or hide by toggling display) ---- */
.upcart-cart .upcart-public-component-product-tile__remove-button{
  appearance: none;
  border: 2px solid var(--fbs-border);
  background: var(--fbs-card);
  border-radius: var(--fbs-radius);
  width: 36px;
  height: 36px;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 0;
  cursor: pointer;
  color: var(--fbs-border);
}

.upcart-cart .upcart-public-component-product-tile__remove-button svg{
  width: 16px;
  height: 16px;
  display: block;
}

.upcart-cart .upcart-public-component-product-tile__remove-button svg path{
  fill: currentColor;
}

/* To hide the remove button entirely, uncomment:
#upCart .upcart-cart .upcart-public-component-product-tile__remove-button{ display:none !important; }
*/

/* ---- Discounts row + tag (“AUTO 5”) ---- */
.upcart-cart .upcart-public-cart-summary__discount-codes{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.upcart-cart .upcart-public-cart-summary__discount-label{
  font-family: var(--fbs-font) !important;
  font-weight: 700 !important;
  color: var(--fbs-border) !important;
}

.upcart-cart .upcart-public-component-tag{
    display: inline-flex;
    align-items: center;
    gap: 8px;

    padding: 6px 10px;
    border: 2px solid var(--fbs-border);
    border-radius: 999px;

    background: transparent;
    color: var(--fbs-border);
  }


.upcart-cart .upcart-public-component-tag__icon svg{
  width: 14px;
  height: 14px;
  display: block;
}

.upcart-cart .upcart-public-component-tag__icon svg path{
  fill: currentColor;
}

.upcart-cart .upcart-public-component-tag__text{
  font-family: var(--fbs-font) !important;
  font-weight: 700 !important;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.2px;
  line-height: 1;
  color: var(--fbs-border) !important;
}

.upcart-cart .upcart-public-cart-summary__total-discount{
  background: transparent !important;
  padding: 0 !important;

  font-family: var(--fbs-font) !important;
  font-weight: 700 !important;
  color: var(--fbs-border) !important;
}

/* ---- Upsells: white cards + black border (loot drop-lite) ---- */
.upcart-cart .upcart-public-component-upsell-tile,
.upcart-cart .upcart-internal-component-upsell-tile{
  background: var(--fbs-card) !important;
  border: 2px solid var(--fbs-border) !important;
  border-radius: var(--fbs-radius-lg) !important;
}

.upcart-cart
.upcart-public-component-upsell-tile__image-container,
.upcart-cart
.upcart-internal-component-upsell-tile__image-container{
  background: var(--fbs-card) !important;
  border: 2px solid var(--fbs-border) !important;
  border-radius: var(--fbs-radius) !important;
  overflow: hidden !important;
}

.upcart-cart
.upcart-public-component-upsell-tile__title,
.upcart-cart
.upcart-internal-component-upsell-tile__title{
  font-family: var(--fbs-font) !important;
  font-weight: 700 !important;
  color: var(--fbs-border) !important;
  text-transform: uppercase;
  letter-spacing: 0.2px;
}

/* ---- CTA button: Final Boss floating yellow w/ black outline + red 3D plate ---- */
.upcart-cart .upcart-checkout-button{
    background: #C81E2A !important;
    color: #FFFFFF !important;

    border: 3px solid var(--fbs-border) !important;
    border-radius: 0px !important;

    box-shadow: 0 8px 0 #FFFFFF !important;
    text-decoration: none !important;

    font-family: var(--fbs-font) !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    letter-spacing: 0.3px;

    padding: 16px 18px !important;
  }

 .upcart-cart .upcart-checkout-button:active{
    transform: translateY(3px);
    box-shadow: 0 5px 0 #FFFFFF !important;
  }

.upcart-footer {
  border-top: 2px solid #000 !important;
  box-sizing: border-box;
}

.upcart-public-component-product-tile {
  border-bottom:  0px solid #000 !important;
}
    </style>
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
