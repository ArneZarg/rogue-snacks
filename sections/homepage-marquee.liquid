<style>
    .homepage-marquee.{{ section.id }} {
        background: {{ section.settings.bg_color }};
        overflow: hidden;
        padding: {{ section.settings.padding_y }}px 0;
        position: relative;
    }
    .homepage-marquee__track.{{ section.id }} {
        display: flex;
        width: max-content;
        animation: marquee-scroll-{{ section.id }} {{ section.settings.speed }}s linear infinite;
    }
    .homepage-marquee__items.{{ section.id }} {
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }
    .homepage-marquee__item.{{ section.id }} {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 0 10px;
        white-space: nowrap;
    }
    .homepage-marquee__text.{{ section.id }} {
        color: {{ section.settings.text_color }};
        font-family: 'Venice Blvd', sans-serif;
        font-size: {{ section.settings.font_size_mobile }}px;
        font-weight: 900;
        font-style: normal;
        line-height: 1.3;
        letter-spacing: -0.02em;
        text-transform: uppercase;
    }
    .homepage-marquee__separator.{{ section.id }} {
        color: {{ section.settings.text_color }};
        font-family: 'Venice Blvd', sans-serif;
        font-size: {{ section.settings.font_size_mobile }}px;
        font-weight: 900;
        line-height: 1.3;
        flex-shrink: 0;
    }
    @media (min-width: 750px) {
        :root {
            --homepage-marquee-height: calc({{ section.settings.font_size }}px * 1.3 + {{ section.settings.padding_y }}px * 2);
        }
        .homepage-marquee__text.{{ section.id }} {
            font-size: {{ section.settings.font_size }}px;
        }
        .homepage-marquee__separator.{{ section.id }} {
            font-size: {{ section.settings.font_size }}px;
        }
    }
    @keyframes marquee-scroll-{{ section.id }} {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
</style>

<section class="homepage-marquee {{ section.id }}" data-section-id="{{ section.id }}">
    <div class="homepage-marquee__track {{ section.id }}" aria-hidden="true">
        {%- for i in (1..2) -%}
            <div class="homepage-marquee__items {{ section.id }}">
                {%- for block in section.blocks -%}
                    <div class="homepage-marquee__item {{ section.id }}" {{ block.shopify_attributes }}>
                        <span class="homepage-marquee__separator {{ section.id }}">·</span>
                        <span class="homepage-marquee__text {{ section.id }}">{{ block.settings.text }}</span>
                    </div>
                {%- endfor -%}
            </div>
        {%- endfor -%}
    </div>
</section>

{% schema %}
{
    "name": "Homepage Marquee",
    "tag": "section",
    "class": "homepage-marquee-section",
    "settings": [
        {
            "type": "header",
            "content": "Style"
        },
        {
            "type": "color",
            "id": "bg_color",
            "label": "Background color",
            "default": "#1D1D1D"
        },
        {
            "type": "color",
            "id": "text_color",
            "label": "Text color",
            "default": "#FFFFFF"
        },
        {
            "type": "range",
            "id": "font_size",
            "label": "Font size (desktop)",
            "min": 16,
            "max": 60,
            "step": 1,
            "unit": "px",
            "default": 35
        },
        {
            "type": "range",
            "id": "font_size_mobile",
            "label": "Font size (mobile)",
            "min": 14,
            "max": 40,
            "step": 1,
            "unit": "px",
            "default": 20
        },
        {
            "type": "range",
            "id": "speed",
            "label": "Scroll speed (seconds)",
            "min": 5,
            "max": 60,
            "step": 1,
            "unit": "s",
            "default": 20
        },
        {
            "type": "range",
            "id": "padding_y",
            "label": "Vertical padding",
            "min": 0,
            "max": 40,
            "step": 2,
            "unit": "px",
            "default": 12
        }
    ],
    "blocks": [
        {
            "type": "text_item",
            "name": "Text Item",
            "settings": [
                {
                    "type": "text",
                    "id": "text",
                    "label": "Text",
                    "default": "Real Protein"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Homepage Marquee",
            "blocks": [
                {
                    "type": "text_item",
                    "settings": { "text": "Real Protein" }
                },
                {
                    "type": "text_item",
                    "settings": { "text": "Max Flavor" }
                },
                {
                    "type": "text_item",
                    "settings": { "text": "Zero Seed Oils" }
                }
            ]
        }
    ]
}
{% endschema %}
