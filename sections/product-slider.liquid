<style>
    .{{ section.id }}{
        padding-top:{{ section.settings.m_padding_top }}px;
        padding-bottom:{{ section.settings.m_padding_bottom }}px;
        background:{{ section.settings.bg_color }};
    }
    .{{ section.id }} h2{
        color:{{ section.settings.text_color }};
        text-align: center;
        font-size: 35px;
        font-style: normal;
        font-weight: 900;
        line-height: 37px;
        letter-spacing: -0.7px;
        text-transform: uppercase;
        margin-bottom:20px;
        position:relative;
        width:fit-content;
        margin-left:auto;
        margin-right:auto;
    }
    .{{ section.id }} p{
        color:{{ section.settings.text_color }};
        font-size: 17px;
        font-style: normal;
        font-weight: 500;
        line-height: normal;
        text-align:center;
    }
    .{{ section.id }} .product-slider-text{
        padding-bottom:30px;
        max-width: 300px;
        margin: auto;
    }
    .{{ section.id }} .accent-img{
        width:70px;
        margin:0 auto;
    }
    .{{ section.id }} .accent-img.desk-accent{
        display:none;
    }
    .{{ section.id }} .product-slider-arrows{
        display:none;
    }
    .{{ section.id }} .rogue-button-prev,
    .{{ section.id }} .rogue-button-next{
        cursor:pointer;
    }
    @media(min-width:750px){
        .{{ section.id }}{
            padding-top:{{ section.settings.d_padding_top }}px;
            padding-bottom:{{ section.settings.d_padding_bottom }}px;
        }
        .{{ section.id }} h2{
            font-size: 50px;
            letter-spacing:-1px;
            text-align:left;
            margin-left:0;
            margin-right:0;
        }
        .{{ section.id }} p{
            text-align:left;
        }
        .{{ section.id }} .product-slider-text{
            padding-bottom:50px;
            max-width:unset;
            display: flex;
            justify-content: space-between;
        }
        .{{ section.id }} .accent-img{
            margin:unset;
            display:none;
        }
        .{{ section.id }} .accent-img.desk-accent{
            display:block;
            position:absolute;
            right: -110px;
            top: -35px;
            width: 110px;
        }
        .{{ section.id }} .product-slider-arrows{
            display: flex;
            gap: 30px;
            align-items: center;
        }
        .{{ section.id }} .full-width-slider {
            padding-right:0;
        }
    }
    .{{ section.id }} .product-slider .swiper-slide{
        height:auto;
    }
    .{{ section.id }} .product-slider .rogue-product-card{
        height:100%;
        display:flex;
        flex-direction:column;
    }
</style>
<section class="{{ section.id }}">
    <div class="page-container-body-wide">
        <div class="product-slider-text">
            <div class="product-text-box">
                {% if section.settings.accent_image != blank %}
                    <div class="accent-img">
                        <img src="{{ section.settings.accent_image | image_url: width: 140 }}" alt="{{ section.settings.accent_image.alt | escape }}" width="70" height="70" loading="lazy">
                    </div>
                {% endif %}
                <h2>
                    {{ section.settings.title }}
                    {% if section.settings.accent_image != blank %}
                        <span class="accent-img desk-accent">
                            <img src="{{ section.settings.accent_image | image_url: width: 220 }}" alt="{{ section.settings.accent_image.alt | escape }}" width="110" height="110" loading="lazy">
                        </span>
                    {% endif %}
                </h2>
                <p>{{ section.settings.subtitle }}</p>
            </div>
            <div class="product-slider-arrows">
                <div class="rogue-button-prev">
                    {% render 'arrow-prev' %}
                </div>
                <div class="rogue-button-next">
                    {% render 'arrow-next' %}
                </div>
            </div>
        </div>
    </div>
    <div class="page-container-body-wide full-width-slider">
        <div class="swiper product-slider">
            <div class="swiper-wrapper">
                {% for block in section.blocks %}
                    <div class="swiper-slide">
                        {% if forloop.first %}
                            {% render 'rogue-product-card' product:block.settings.product, card_image:block.settings.product_image, card_background:'linear-gradient(340deg, #6E00FF 0.97%, #07F 100%)' %}
                        {% else %}
                            {% render 'rogue-product-card' product:block.settings.product, card_image:block.settings.product_image %}
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
<script>
    {
        const slider = new Swiper('.{{ section.id }} .product-slider',{
            loop:false,
            slidesPerView:1,
            spaceBetween:10,
            breakpoints:{
                750:{
                    slidesPerView:3.5,
                    spaceBetween:25,
                    slidesOffsetAfter:90
                }
            },
            navigation:{
                nextEl:'.{{ section.id }} .rogue-button-next',
                prevEl:'.{{ section.id }} .rogue-button-prev'
            }
        });
    }
</script>
{% schema %}
{
    "presets": [
        {
            "name":"Product Slider"
        }
    ],
    "settings": [
        {
            "type":"header",
            "content": "Text"
        },
        {
            "type": "text",
            "id": "title",
            "default":"GO ROGUE. EAT THEM ALL.",
            "label": "Title"
        },
        {
            "type": "text",
            "id": "subtitle",
            "label": "Subtitle",
            "default":"Protein snacks that hit like junk food — without the junk."
        },
        {
            "type":"header",
            "content": "Images"
        },
        {
            "type": "image_picker",
            "id": "accent_image",
            "label": "Accent Image",
            "info": "Decorative image shown near the title (e.g. chip illustration)"
        },
        {
            "type":"header",
            "content": "Background and Colours"
        },
        {
            "type": "color",
            "id":"bg_color",
            "label": "Background Color",
            "default":"#FFFFFF"
        },
        {
            "type": "color",
            "id":"text_color",
            "label": "Text Color",
            "default":"#1D1D1D"
        },
        {
            "type":"header",
            "content": "Padding"
        },
        {
            "type": "range",
            "id": "d_padding_top",
            "default":90,
            "label": "Padding Top (Desktop)",
            "min": 20,
            "max": 200,
            "step": 10,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "d_padding_bottom",
            "default":180,
            "label": "Padding Bottom  (Desktop)",
            "min": 20,
            "max": 200,
            "step": 10,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "m_padding_top",
            "default":90,
            "label": "Padding Top (Mobile)",
            "min": 20,
            "max": 100,
            "step": 5,
            "unit": "px"
        },
        {
            "type": "range",
            "id": "m_padding_bottom",
            "default":50,
            "label": "Padding Bottom  (Mobile)",
            "min": 20,
            "max": 100,
            "step": 5,
            "unit": "px"
        }
    ],
    "blocks": [
        {
            "type": "product",
            "name": "Product",
            "limit": 5,
            "settings": [
                {
                    "type": "product",
                    "label":"Product",
                    "id": "product"
                },
                {
                    "type": "image_picker",
                    "label": "Product Image",
                    "id": "product_image",
                    "info": "Overrides the default product featured image"
                }
            ]
        }
    ]
}
{% endschema %}
