{% style %}
.sticky-atc-container{
    position: fixed;
    bottom: 12px;
    width: 85%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 40;
}
.sticky-atc{
    display: flex;
    width: 100%;
    flex-direction: row;
    justify-content: space-between;
    padding-inline: 20px;
}
.sticky-atc .cta{
    font-size: 18px;
    text-transform: uppercase;
}
@media(min-width:1024px){
    .sticky-atc-container{ display: none; }
}
{% endstyle %}

<div class="sticky-atc-container">
    <button type="button" class="sticky-atc rogue-component-btn rogue-btn-yellow">
        <span><span class="cta">Add to Cart</span></span>
        <span>
            <span class="compare-at-price">
                {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
                    {{ product.selected_or_first_available_variant.compare_at_price | money_without_trailing_zeros }}
                {% endif %}
            </span>
            <span class="price">
                {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}
            </span>
        </span>
    </button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const stickyContainer = document.querySelector('.sticky-atc-container');
    const stickyBtn = document.querySelector('.sticky-atc');
    const myATC = document.querySelector('.add-to-cart-button');

    if (!stickyContainer || !stickyBtn || !myATC) return;

    const stickyPrice = stickyBtn.querySelector('.price');
    const stickyCompare = stickyBtn.querySelector('.compare-at-price');

    // Works whether there's a variant form, product form, or neither
    const myform =
        document.querySelector('.variant-picker__form') ||
        myATC.closest('form') ||
        document.querySelector('product-form form') ||
        document.querySelector('form[action*="/cart/add"]');

    function syncStickyButton() {
        const mainPrice = myATC.querySelector('.price');
        const mainCompare = myATC.querySelector('.compare-at-price');

        if (mainPrice && stickyPrice) {
            stickyPrice.textContent = mainPrice.textContent.trim();
        }

        if (stickyCompare) {
            if (mainCompare) {
                const compareText = mainCompare.textContent.trim();
                stickyCompare.textContent = compareText;
                stickyCompare.style.display = compareText ? '' : 'none';
            } else {
                stickyCompare.textContent = '';
                stickyCompare.style.display = 'none';
            }
        }

        stickyBtn.disabled = myATC.disabled;
    }

    function updateVisibility() {
        const rect = myATC.getBoundingClientRect();
        const inView = rect.top < window.innerHeight && rect.bottom > 0;
        stickyContainer.style.display = inView ? 'none' : '';
    }

    function syncAfterUpdate() {
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                syncStickyButton();
                updateVisibility();
            });
        });
    }

    window.addEventListener('scroll', updateVisibility, { passive: true });
    window.addEventListener('resize', updateVisibility);

    if (myform) {
        myform.addEventListener('change', syncAfterUpdate);
    }

    const mo = new MutationObserver(syncAfterUpdate);
    mo.observe(myATC, {
        childList: true,
        subtree: true,
        characterData: true,
        attributes: true
    });

    stickyBtn.addEventListener('click', function () {
        
        if (!myATC.disabled) {
            myATC.click();
        }
    });

    syncStickyButton();
    updateVisibility();
});
</script>

{% schema %}
{
    "name": "Sticky ATC",
    "presets": [
        {
            "name": "Sticky ATC"
        }
    ]
}
{% endschema %}