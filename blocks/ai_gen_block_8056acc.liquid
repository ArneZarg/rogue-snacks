{% doc %}
  @prompt
    2 buttons one for tik tok the other for instagram both that link our too 2 links they should both use the comapnies respective logs it should be 2 columns on desktop one on mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-social-buttons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-social-buttons-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-social-button-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: {{ block.settings.button_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: {{ block.settings.font_size }}px;
    font-weight: 600;
  }

  .ai-social-button-tiktok-{{ ai_gen_id }} {
    background-color: {{ block.settings.tiktok_bg_color }};
    color: {{ block.settings.tiktok_text_color }};
  }

  .ai-social-button-tiktok-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tiktok_hover_bg_color }};
    color: {{ block.settings.tiktok_hover_text_color }};
  }

  .ai-social-button-instagram-{{ ai_gen_id }} {
    background-color: {{ block.settings.instagram_bg_color }};
    color: {{ block.settings.instagram_text_color }};
  }

  .ai-social-button-instagram-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.instagram_hover_bg_color }};
    color: {{ block.settings.instagram_hover_text_color }};
  }

  .ai-social-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-social-buttons-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<social-buttons-{{ ai_gen_id }}
  class="ai-social-buttons-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-social-buttons-container-{{ ai_gen_id }}">
    {% if block.settings.tiktok_link != blank %}
      <a
        href="{{ block.settings.tiktok_link }}"
        class="ai-social-button-{{ ai_gen_id }} ai-social-button-tiktok-{{ ai_gen_id }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit our TikTok"
      >
        <svg
          class="ai-social-icon-{{ ai_gen_id }}"
          viewBox="0 0 24 24"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
        </svg>
        <span>{{ block.settings.tiktok_text }}</span>
      </a>
    {% endif %}

    {% if block.settings.instagram_link != blank %}
      <a
        href="{{ block.settings.instagram_link }}"
        class="ai-social-button-{{ ai_gen_id }} ai-social-button-instagram-{{ ai_gen_id }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit our Instagram"
      >
        <svg
          class="ai-social-icon-{{ ai_gen_id }}"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          xmlns="http://www.w3.org/2000/svg"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
        <span>{{ block.settings.instagram_text }}</span>
      </a>
    {% endif %}
  </div>
</social-buttons-{{ ai_gen_id }}>

<script>
  (function() {
    class SocialButtons{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('social-buttons-{{ ai_gen_id }}', SocialButtons{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Social media buttons",
  "settings": [
    {
      "type": "header",
      "content": "TikTok"
    },
    {
      "type": "url",
      "id": "tiktok_link",
      "label": "TikTok link"
    },
    {
      "type": "text",
      "id": "tiktok_text",
      "label": "Button text",
      "default": "Follow on TikTok"
    },
    {
      "type": "color",
      "id": "tiktok_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "tiktok_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tiktok_hover_bg_color",
      "label": "Hover background color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "tiktok_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Instagram"
    },
    {
      "type": "url",
      "id": "instagram_link",
      "label": "Instagram link"
    },
    {
      "type": "text",
      "id": "instagram_text",
      "label": "Button text",
      "default": "Follow on Instagram"
    },
    {
      "type": "color",
      "id": "instagram_bg_color",
      "label": "Background color",
      "default": "#E4405F"
    },
    {
      "type": "color",
      "id": "instagram_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "instagram_hover_bg_color",
      "label": "Hover background color",
      "default": "#C13584"
    },
    {
      "type": "color",
      "id": "instagram_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Button padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between buttons",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Social media buttons"
    }
  ]
}
{% endschema %}
