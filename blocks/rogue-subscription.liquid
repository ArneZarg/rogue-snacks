{% style %}
/* Hide Skio UI but keep functionality */
.shopify-app-block .skio-plan-picker {
  position: absolute !important;
  left: -9999px !important;
  width: 1px !important;
  height: 1px !important;
  overflow: hidden !important;
  opacity: 0 !important;
  pointer-events: none !important;
}

.custom-subscription-picker {
  margin-top: 14px;
  margin-bottom: 14px;
  width: 100%;
  max-width: 100%;
  flex: 1 1 auto;
  align-self: stretch;
  justify-self: stretch !important;
}

.custom-subscription-switch {
  display: grid !important;
  grid-template-columns: 1fr 1fr !important;
  gap: 0;
  padding: 0;
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
  box-sizing: border-box !important;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.75);
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  overflow: hidden;
}

.custom-subscription-switch__option {
  appearance: none;
  -webkit-appearance: none;
  border: 0;
  outline: 0;
  background: transparent;
  color: #ffffff;
  border-radius: 999px;
  min-height: 32px;
  padding: 15px 14px;
  font-size: 14px;
  line-height: 1;
  font-weight: 500;
  text-align: center;
  cursor: pointer;
  transition:
    background 0.2s ease,
    color 0.2s ease,
    box-shadow 0.2s ease;
  white-space: nowrap;
  width: 100% !important;
  min-width: 0 !important;
  box-sizing: border-box !important;
  justify-self: stretch;
  position: relative;
}

.custom-subscription-switch__option.is-active {
  background: #f3f1ee;
  color: #111111;
  box-shadow: none;
  font-weight: bold;
  position: relative;
}

.custom-subscription-switch__option.is-active::before {
  position: absolute;
  content: '';
  width: 100%;
  height: 100%;
  border: 1px solid #fff;
  inset: 0;
  border-radius: 999px;
  pointer-events: none;
}

.custom-subscription-switch__option::before,
.custom-subscription-switch__option::after {
  content: none !important;
}

.option-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 5px;
}

.check-sub {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.8);
  width: 0;
  overflow: hidden;
  transition: opacity 0.2s ease, transform 0.2s ease, width 0.2s ease;
}

.custom-subscription-switch__option.is-active .check-sub {
  opacity: 1;
  transform: scale(1);
  width: 20px;
}

.custom-subscription-helper {
  margin-top: 6px;
  font-size: 12px;
  line-height: 1.25;
  color: rgba(255, 255, 255, 0.92);
  text-align: left;
  display: none;
}

.custom-subscription-helper__link {
  color: inherit;
  text-decoration: underline;
  margin-left: 6px;
}

.custom-subscription-picker:has(
  .custom-subscription-switch__option[data-custom-skio-option="sub"].is-active
) .custom-subscription-helper {
  display: block;
}

.shopify-block,
.shopify-app-block,
.custom-subscription-picker {
  display: block !important;
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
}

@media (max-width: 767px) {
  .custom-subscription-switch__option {
    min-height: 30px;
    padding: 0 10px;
    font-size: 11px;
  }

  .custom-subscription-helper {
    font-size: 11px;
  }
}
{% endstyle %}

