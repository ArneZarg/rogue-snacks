<div
  class="
    contact-form
    spacing-style size-style
    {% if block.settings.inherit_color_scheme == false %}color-{{ block.settings.color_scheme }}{% endif %}
  "
  style="
    {% render 'spacing-style', settings: block.settings %}
    {% render 'size-style', settings: block.settings %}
  "
  {{ block.shopify_attributes }}
>
  {% assign form_id = block.id | default: section.id | prepend: 'ContactForm-' %}

  {%- form 'contact', id: form_id, class: 'contact-form__form' -%}
    {%- assign is_success_state = false -%}
    {%- if form.posted_successfully? and form.id == form_id -%}
      {%- assign is_success_state = true -%}
    {%- endif -%}

    <input
      name="contact[id]"
      type="hidden"
      value="{{ form_id }}"
    >

    <div class="contact-form__fields"{% if is_success_state %} hidden{% endif %}>
      {%- if form.errors and form.id == form_id -%}
        <div
          class="contact-form__error"
          tabindex="-1"
          autofocus
        >
          {{ 'icon-error.svg' | inline_asset_content }}
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="contact-form__form-row">
        <label class="visually-hidden" for="{{ form_id }}-name">
          {{ 'blocks.contact_form.name' | t }}
        </label>
        <input
          type="text"
          id="{{ form_id }}-name"
          class="contact-form__input"
          autocomplete="name"
          name="contact[name]"
          value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
          placeholder="{{ 'blocks.contact_form.name' | t }}"
        >

        <label class="visually-hidden" for="{{ form_id }}-email">
          {{ 'blocks.contact_form.email' | t }}
          <span aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="{{ form_id }}-email"
          class="contact-form__input"
          autocomplete="email"
          name="contact[email]"
          spellcheck="false"
          autocapitalize="off"
          value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          aria-required="true"
          required
          {% if form.errors contains 'email' and form.id == form_id %}
            aria-invalid="true"
            aria-describedby="{{ form_id }}-email-error"
          {% endif %}
          placeholder="{{ 'blocks.contact_form.email' | t }}"
        >
      </div>

      <label class="visually-hidden" for="{{ form_id }}-phone">
        {{ 'blocks.contact_form.phone' | t }}
      </label>
      <input
        type="tel"
        id="{{ form_id }}-phone"
        class="contact-form__input"
        autocomplete="tel"
        name="contact[phone]"
        pattern="[0-9\-+\s()]*"
        value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
        placeholder="{{ 'blocks.contact_form.phone' | t }}"
      >

      <label class="visually-hidden" for="{{ form_id }}-body">
        {{ 'blocks.contact_form.comment' | t }}
      </label>
      <textarea
        rows="10"
        id="{{ form_id }}-body"
        class="contact-form__input contact-form__input--textarea"
        name="contact[body]"
        placeholder="{{ 'blocks.contact_form.comment' | t }}"
      >{{- form.body -}}</textarea>

      <button
        type="submit"
        class="button submit-button"
      >
        Send
      </button>
    </div>

    <div
      class="contact-form__submission"
      tabindex="-1"
      {% if is_success_state %}autofocus{% else %}hidden{% endif %}
    >
      {%- if block.settings.success_image != blank -%}
        {{
          block.settings.success_image
          | image_url: width: 360
          | image_tag:
            widths: '120, 180, 240, 360',
            sizes: '(min-width: 750px) 120px, 80px',
            class: 'contact-form__submission-image',
            alt: ''
        }}
      {%- endif -%}
      {%- if block.settings.success_headline != blank -%}
        <h2 class="contact-form__submission-headline">{{ block.settings.success_headline }}</h2>
      {%- endif -%}
      {%- if block.settings.success_subheadline != blank -%}
        <div class="contact-form__submission-subheadline">{{ block.settings.success_subheadline }}</div>
      {%- endif -%}
    </div>
  {%- endform -%}
</div>

<script>
  (function () {
    if (!new URLSearchParams(location.search).has('preview_success')) return;
    document.querySelectorAll('.contact-form').forEach(function (container) {
      var fields = container.querySelector('.contact-form__fields');
      var submission = container.querySelector('.contact-form__submission');
      if (fields) fields.hidden = true;
      if (submission) submission.hidden = false;
    });
  })();
</script>

{% stylesheet %}
  .contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .contact-form__fields {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .contact-form__fields[hidden],
  .contact-form__submission[hidden] {
    display: none;
  }

  .contact-form__form-row {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  @media screen and (min-width: 750px) {
    .contact-form__form-row {
      flex-direction: row;
      align-items: center;
    }
  }

  .contact-form__input {
    width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--color-input-text);
    background-color: var(--color-input-background);
    padding: var(--padding-lg) var(--padding-xl);
    border-radius: var(--style-border-radius-inputs);
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    -webkit-font-smoothing: antialiased;
  }

  .contact-form__input--textarea {
    resize: vertical;
    min-height: var(--input-textarea-min-height);
  }

  .contact-form__error,
  .contact-form__success {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
  }

  .contact-form__submission {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--gap-md);
  }

  .contact-form__submission-image {
    width: 80px;
    max-width: 100%;
    height: auto;
  }

  @media screen and (min-width: 750px) {
    .contact-form__submission-image {
      width: 100px;
    }
  }

  .contact-form__submission-headline {
    margin: 0;
  }

  .contact-form__submission-subheadline {
    margin: 0;
  }

  .contact-form__submission-subheadline > * {
    margin: 0;
  }

  .submit-button {
    min-width: max-content;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.contact_form",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Submission success"
    },
    {
      "type": "image_picker",
      "id": "success_image",
      "label": "Image"
    },
    {
      "type": "inline_richtext",
      "id": "success_headline",
      "label": "Headline",
      "default": "Submission confirmed."
    },
    {
      "type": "richtext",
      "id": "success_subheadline",
      "label": "Subheadline",
      "default": "<p>Thanks for reaching out. Your inquiry has been successfully submitted and our team will respond shortly.</p>"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.contact_form",
      "category": "t:categories.forms"
    }
  ]
}
{% endschema %}